<mujoco> <!-- Root element of the MuJoCo model -->
	
	<asset>
   
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".2 .3 .4" rgb2=".3 .4 .5"/>
    <material name="grid_mat" texture="grid" texrepeat="10 10" reflectance="0.1"/>
    <material name="ground_mat" rgba=".8 .8 .8 1" reflectance="0.1"/>
</asset> 

<visual>
    <global offwidth="640" offheight="480"/>
</visual>
	<!-- Simulation options -->
	<option gravity="0 0 -9.81" /> <!-- Set gravity (z-axis downward) -->
	<worldbody> <!-- Contains all physical objects in the world -->
        <!-- diffuse = light color/intensity, pos = position, dir = direction -->
		 <!-- Multiple lights for better visualization -->
<light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1" castshadow="true"/>
<!-- castshadow="true" = shadows enable -->
<light diffuse=".3 .3 .3" pos="2 2 2" dir="-1 -1 -1"/>
<!-- Side light for fill -->
<light diffuse=".2 .2 .2" pos="-2 -2 2" dir="1 1 -1"/>
<!-- Back light for rim effect -->
		<!-- Ground plane -->
		 <!-- <geom type="plane" size="5 5 0.1" material="grid_mat"/> -->
		 <geom type="plane" size="5 5 0.1" rgba=".9 .9 .9 1"/>
		<!-- Large flat surface for robot to move on -->

		<!-- Main robot body -->
		<body name="chassis" pos="0 0 0.2" euler='0 90 0'>
		<!-- pos = initial position (x,y,z)
		     euler = rotation (degrees) -->

			<!-- Free joint allows full 6-DOF movement (x,y,z + rotation) -->
			<joint type="free"/>
			
             <!-- Camera housing (black box) -->
            <geom name="front_cam_housing" type="box" pos="0 0 0.52" size="0.09 0.04 0.02" rgba="0.1 0.1 0.1 1"/>
            <!-- Camera lens (blue) -->
            <geom name="front_cam_lens" type="cylinder" pos="0 0 0.55" size="0.015 0.005" euler="90 0 0" rgba="0.2 0.4 0.8 1"/>
            <!-- MuJoCo camera -->
            <camera name="front_cam" pos="0 0 0.6" euler="0 0 0" fovy="60"/>
            
            <!-- ===== REAR CAMERA ===== -->
            <!-- Camera housing (black box) -->
            <geom name="rear_cam_housing" type="box" pos="0 0 -0.52" size="0.09 0.04 0.02" rgba="0.1 0.1 0.1 1"/>
            <!-- Camera lens (red) -->
            <geom name="rear_cam_lens" type="cylinder" pos="0 0 -0.55" size="0.015 0.005" euler="90 0 0" rgba="0.8 0.2 0.2 1"/>
            <!-- MuJoCo camera -->
            <camera name="rear_cam" pos="0 0 -0.6" euler="0 0 180" fovy="60"/>
            <camera name="cam1" mode="trackcom" target="chassis" pos="0 0 1" fovy="60"/>

			<!-- Chassis geometry (box shape) -->
			<geom type="box" size=".05 .2 0.6" rgba=".9 .9 0 1"/>
			<!-- size = half-lengths (x,y,z), color = yellow -->


			<!-- Marker site (used for sensors/tracking) -->
			<site name="marker" pos="0 0 0.0" size="0.14" rgba="1 0 0 0" />
			<!-- A reference point on the robot -->
        
			<!-- Left wheel -->
			<body name="left-tire" pos="0 0.26 -0.5" euler='90 0 0'>
			<!-- Positioned to left side of chassis -->

				<!-- Hinge joint for wheel rotation -->
				<joint name="left-wheel" type="hinge" axis="0 0 -1"/>
				<!-- Rotates around Z-axis -->



				<!-- Wheel geometry -->
				<geom type="cylinder" size=".2 0.05" rgba="0 .9 0 1" friction="0 0.1 0.1"/>

				
				<!-- size = radius, half-length -->
			</body>

			<!-- Right wheel -->
			<body name="right-tire" pos="0 -0.26 -0.5" euler='90 0 0'>
			<!-- Positioned to right side -->

				<!-- Hinge joint -->
				<joint name="right-wheel" type="hinge" axis="0 0 -1"/>

				<!-- Wheel geometry -->
				<geom type="cylinder" size=".2 0.05" rgba="0 .9 0 1" friction="0 0.1 0.1"/>
			</body>
						

						<!-- CASTER WHEEL - Added at the back for stability -->
			<body name="caster-wheel" pos="0 0 0.0" euler='0 0 0'>
				<!-- Inertial properties for swivel base -->
				<inertial pos="0 0 0" mass="0.5" diaginertia="0.001 0.001 0.001"/>
				
				<!-- Swivel joint - allows caster to rotate horizontally -->
				<joint name="caster-swivel" type="hinge" axis="0 0 1" range="-180 180" damping="0.1"/>

				<!-- Caster fork + wheel -->
				<body name="caster-fork" pos="0 0 0.0" euler='0 0 0'>
					<!-- Inertial properties for fork + wheel -->
					<inertial pos="0 0 0" mass="0.3" diaginertia="0.0005 0.0005 0.0005"/>
					
					<!-- Wheel rotation joint -->
					<joint name="caster-wheel-joint" type="hinge" axis="0 1 0"/>
					
					<!-- Caster wheel geometry -->
					<geom type="sphere" size="0.14" rgba="0.5 0.5 0.5 1" mass="0.2"/>
				</body>
			</body>
			<!-- END CASTER WHEEL -->

		</body>
	</worldbody>

	<!-- Sensors -->
	<sensor>
		<!-- Tracks position of the "marker" site -->
		<framepos objtype="site" objname="marker"/>
		<!-- Outputs (x, y, z) of marker in world frame -->
	</sensor>

	<!-- Actuators (motors/controllers) -->
	<actuator>

		<!-- Velocity servo for left wheel -->
		<velocity name="left-velocity-servo" joint="left-wheel" kv="100"/>
		<!-- kv = gain (how strongly it tries to match target velocity) -->

		<!-- Velocity servo for right wheel -->
		<velocity name="right-velocity-servo" joint="right-wheel" kv="100"/>

	</actuator>

</mujoco> <!-- End of model -->




